    {
      "parameters": {
        "jsCode": "// Extract Request Data - CORRECTED\nconst body = $input.first().json.body || {};\nconst binary = $input.item.binary || {};\nconst files = [];\n// Check if files came as binary (multipart/form-data)\nif (Object.keys(binary).length > 0) {\n  Object.keys(binary).forEach(key => {\n    const binaryData = binary[key];\n    files.push({\n      name: binaryData.fileName || key,\n      mimeType: binaryData.mimeType || 'application/pdf',\n      size: binaryData.fileSize || 0,\n      extension: (binaryData.fileName || key).split('.').pop().toLowerCase(),\n      data: null, // No base64 needed, using binary directly\n      key: key,\n      isBinary: true\n    });\n  });\n}\n// Check if files came as JSON with base64\nelse if (body.files && Array.isArray(body.files)) {\n  body.files.forEach((file, index) => {\n    files.push({\n      name: file.name || `file${index}.pdf`,\n      mimeType: file.mimeType || 'application/pdf',\n      size: file.size || 0,\n      extension: file.extension || 'pdf',\n      data: file.data, // Base64 string\n      key: file.key || `file${index}`,\n      isBinary: false\n    });\n  });\n}\n\nreturn {\n  json: {\n    files: files,\n    message: body.message || $input.first().json.body.query || '',\n    sessionId: body.session_id || `session-${Date.now()}`,\n    userId: body.user_id || 'anonymous',\n    hasFiles: files.length > 0,\n    hasMessage: (body.message || '').trim().length > 0,\n    // Debug info\n    _debug: {\n      hasBinaryInput: Object.keys(binary).length > 0,\n      hasJsonFiles: !!(body.files && body.files.length > 0),\n      fileCount: files.length\n    }\n  },\n  binary: binary\n};"
      },
